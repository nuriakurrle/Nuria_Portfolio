/* ─────────────────────────────────────────────────────────────────────
   TECH STACK — name → local logo map.
   Only entries listed here render with a logo image; anything not in the
   map falls back to a clean text-only tile (still styled, just no icon).
───────────────────────────────────────────────────────────────────── */
const TOOL_LOGOS = {
  /* exact-name matches */
  'Figma':                    'assets/logos/figma_logo.png',
  'FigJam':                   'assets/logos/figma_logo.png',
  'React':                    'assets/logos/react_logo.png',
  'React / Next.js':          'assets/logos/react_logo.png',
  'TypeScript / React':       'assets/logos/react_logo.png',
  'Next.js':                  'assets/logos/react_logo.png',
  'HTML / CSS':               'assets/logos/html_css_logo.png',
  'HTML/CSS':                 'assets/logos/html_css_logo.png',
  'n8n':                      'assets/logos/n8n_logo.png',
  'n8n (Grundkenntnisse)':    'assets/logos/n8n_logo.png',
  'n8n (basics)':             'assets/logos/n8n_logo.png',
  'Node.js':                  'assets/logos/nodejs_logo.png',
  'Python':                   'assets/logos/python.png',
  'Python (Grundkenntnisse)': 'assets/logos/python.png',
  'Python (basics)':          'assets/logos/python.png',
  'OpenAI API':               'assets/logos/openai.png',
  'OpenAI':                   'assets/logos/openai.png',
  'ChatGPT':                  'assets/logos/openai.png',
  'Docker':                   'assets/logos/docker_logo.png',
};

function getToolLogo(name) {
  if (!name) return null;
  if (TOOL_LOGOS[name]) return TOOL_LOGOS[name];
  /* loose match: any known token appearing in the name */
  const lower = name.toLowerCase();
  const key = Object.keys(TOOL_LOGOS).find(k => lower.includes(k.toLowerCase().split(' ')[0]));
  return key ? TOOL_LOGOS[key] : null;
}

function TechStack({ items, title }) {
  if (!items || !items.length) return null;
  return (
    <div className="tech-items" role="list">
      {items.map((name, i) => {
        const logo = getToolLogo(name);
        return (
          <div key={`${name}-${i}`} className={`tech-item ${logo ? 'has-logo' : 'no-logo'}`} role="listitem" title={name}>
            {logo
              ? <img src={logo} alt={name} loading="lazy" />
              : <span className="tech-glyph" aria-hidden="true">⚙️</span>}
            <span>{name}</span>
          </div>
        );
      })}
    </div>
  );
}

