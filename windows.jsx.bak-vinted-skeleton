/* Skill bar percentages — read from t.skill_bars by matching the label
   text to a SKILL_CATALOG key. Skills without a bar entry render without
   the progress strip (we don't fake numbers). */
function pctFor(skillKey, t) {
  const map = {
    figma:    /^Figma$/i,
    research: /User Research/i,
    service:  /Service Design/i,
    react:    /TypeScript\s*\/\s*React|React/i,
    n8n:      /n8n/i,
  };
  const rx = map[skillKey];
  if (!rx) return null;
  return (t.skill_bars || []).find(b => rx.test(b.label))?.pct ?? null;
}

/* Categorise a timeline item from its title — keeps data.jsx untouched */
function timelineCat(title) {
  if (/Colegio|Spanien|Andalusien|exchange|Auslandsj/i.test(title)) return 'ausland';
  if (/B\.Sc|Abitur|Hochschule|Bachelor|Therese|Klasse|Computer Science|Informatik/i.test(title)) return 'studium';
  return 'job';
}

